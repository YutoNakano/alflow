    "@google/generative-ai": "^0.24.1",
    "@inquirer/prompts": "^7.0.0",
    "archiver": "^7.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "openai": "^6.22.0",
    "plist": "^3.1.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.0",
    "@types/node": "^20.0.0",
    "@types/plist": "^3.0.5",
    "typescript": "^5.5.0",
