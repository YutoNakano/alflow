{
  "name": "alflow",
  "version": "1.0.0",
  "description": "CLI tool to generate Alfred workflows programmatically",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "alflow": "./dist/index.js"
  },
  "scripts": {
